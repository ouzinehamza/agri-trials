# Agri-Trials — production .env template (per-company install, SPEC §10).
# Copy to .env, replace every CHANGE_ME, then run: php artisan key:generate && php artisan agri:preflight
# Values marked CHANGE_ME are secrets — never commit the resulting .env.

APP_NAME="Agri-Trials"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://agri-trials.agrimenara.com
APP_HOST=agri-trials.agrimenara.com

TRAEFIK_NETWORK=gateway
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
CONTENT_LOCALES=fr,en          # add ar (RTL) / es as needed

BCRYPT_ROUNDS=12

# Logs: keep noise low and never log debug in production.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- Database (bundled postgres service) ---
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=agritrials
DB_USERNAME=agri
DB_PASSWORD=P@ssw0rd2026

# --- Sessions: encrypted, HTTPS-only cookies ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Cache + queue on Redis ---
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=P@ssw0rd2026
REDIS_PORT=6379

# --- Object storage (bundled MinIO); firewall ports 9000/9001 ---
FILESYSTEM_DISK=media
MEDIA_DISK=media
MINIO_ROOT_USER=agriadmin
MINIO_ROOT_PASSWORD=P@ssw0rd2026
MINIO_BUCKET=agri-media
MINIO_ENDPOINT=http://minio:9000

# --- Mail (for alerts/notifications) ---
MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME_smtp_host
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME_smtp_user
MAIL_PASSWORD=CHANGE_ME_smtp_password
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="trials@your-company.example"
MAIL_FROM_NAME="${APP_NAME}"

# --- Backups (used by scripts/backup.sh) ---
BACKUP_DIR=backups
BACKUP_RETENTION=14
